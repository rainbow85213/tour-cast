meta {
  name: 02 지도용 일정 조회 (카테고리 필터)
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/schedule/map?userId={{userId}}&date=2026-03-21&filters=restaurant
  body: none
  auth: none
}

tests {
  test("200 반환", function() {
    expect(res.status).to.equal(200);
  });

  test("restaurant 카테고리만 반환", function() {
    const items = res.body.items;
    items.forEach(function(item) {
      expect(item.category).to.equal("restaurant");
    });
  });
}
