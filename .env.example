PORT=3000
NODE_ENV=development

TOUR_API_KEY=your_tour_api_key
CAMP_API_KEY=your_camp_api_key
WEATHER_API_KEY=your_weather_api_key
KAKAO_API_KEY=your_kakao_rest_api_key
PUBLIC_DATA_API_KEY=your_public_data_api_key

DB_HOST=localhost
DB_PORT=3309
DB_NAME=tour_cast
DB_USER=tour_cast
DB_PASSWORD=your_password

DATABASE_URL="postgresql://tour_cast:your_password@localhost:3309/tour_cast?schema=public"

REDIS_URL=redis://localhost:6379

# CORS 허용 도메인 (쉼표 구분, 미설정 시 전체 허용)
# 운영 예시: ALLOWED_ORIGINS=https://example.com,https://www.example.com
ALLOWED_ORIGINS=

# 서비스간 인증 키 (TravelPlatform → TourCast 호출 시 Authorization: Bearer {key})
# 미설정 시 개발 모드로 간주하여 인증 없이 통과
SERVICE_API_KEY=

# Firebase Admin SDK 서비스 계정 JSON (FCM 푸시 알림)
# Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > 새 비공개 키 생성
# JSON 파일 내용을 한 줄로 직렬화하여 입력: cat service-account.json | jq -c .
FIREBASE_SERVICE_ACCOUNT_JSON=
