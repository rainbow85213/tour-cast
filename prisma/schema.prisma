generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model TouristSpot {
  id        Int      @id @default(autoincrement())
  contentId String   @unique
  title     String
  address   String?
  mapX      Float?
  mapY      Float?
  image     String?
  overview  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tourist_spots")
}

model Accommodation {
  id        Int      @id @default(autoincrement())
  contentId String   @unique
  title     String
  address   String?
  mapX      Float?
  mapY      Float?
  tel       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("accommodations")
}

model Festival {
  id        Int      @id @default(autoincrement())
  contentId String   @unique
  title     String
  address   String?
  mapX      Float?
  mapY      Float?
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("festivals")
}

model Campsite {
  id        Int      @id @default(autoincrement())
  contentId String   @unique
  title     String
  address   String?
  mapX      Float?
  mapY      Float?
  induty    String?
  resveUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("campsites")
}

model Schedule {
  id            String   @id @default(cuid())
  userId        String
  title         String
  description   String?
  scheduledAt   DateTime
  location      Json     // { name, address, lat, lng, category }
  completed         Boolean  @default(false)
  publicDataRef     String?
  deviceToken       String?
  notificationSent  String[] @default([])
  createdAt         DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([scheduledAt])
  @@map("schedules")
}

model TravelPlan {
  id         String           @id @default(cuid())
  userId     String
  date       String           // YYYY-MM-DD
  title      String
  sourceText String?
  createdAt  DateTime         @default(now())
  items      TravelPlanItem[]

  @@index([userId])
  @@map("travel_plans")
}

// 고양시 통합 장소 데이터
// contentTypeId: 12=관광지, 14=문화시설, 15=축제/행사, 28=레포츠, 38=쇼핑, 39=음식점
model GoyangPlace {
  id            Int       @id @default(autoincrement())
  contentId     String    @unique
  contentTypeId Int
  category      String    // tourist_spot | cultural | festival | sports | shopping | restaurant
  title         String
  address       String?
  mapX          Float?
  mapY          Float?
  image         String?
  tel           String?
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([category])
  @@index([contentTypeId])
  @@map("goyang_places")
}

model TravelPlanItem {
  id          String     @id @default(cuid())
  planId      String
  plan        TravelPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  title       String
  latitude    Float
  longitude   Float
  status      String     @default("pending")
  time        String
  scheduledAt DateTime?
  category    String
  description String?
  order       Int
  createdAt   DateTime   @default(now())

  @@index([planId])
  @@map("travel_plan_items")
}
